# Capture the set of staged files before formatting
STAGED_FILES=$(git diff --cached --name-only)
bun install
bun run fmt
# Re-stage only files that still exist (modified/added); deleted files stay staged as deletion
echo "$STAGED_FILES" | while IFS= read -r f; do
  if [ -f "$f" ]; then
    git add "$f"
  fi
done
bun run lint
bun run check-types