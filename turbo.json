{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "web#dev": {
      "dependsOn": ["@myakiba/db#db:start", "@myakiba/redis#redis:start"],
      "with": ["@myakiba/db#db:studio"],
      "cache": false,
      "persistent": true
    },
    "server#dev": {
      "dependsOn": ["@myakiba/db#db:start", "@myakiba/redis#redis:start"],
      "with": ["@myakiba/db#db:studio"],
      "cache": false,
      "persistent": true
    },
    "worker#dev": {
      "dependsOn": ["@myakiba/db#db:start", "@myakiba/redis#redis:start"],
      "with": ["@myakiba/db#db:studio"],
      "cache": false,
      "persistent": true
    },
    "stop": {
      "cache": false
    },
    "db:push": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:push:interactive": {
      "cache": false,
      "env": ["DATABASE_URL"],
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "@myakiba/db#db:studio": {
      "dependsOn": ["@myakiba/db#db:start"],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:start": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:watch": {
      "cache": false,
      "persistent": true
    },
    "db:stop": {
      "cache": false
    },
    "db:down": {
      "cache": false
    },
    "redis:start": {
      "cache": false
    },
    "redis:stop": {
      "cache": false
    },
    "redis:down": {
      "cache": false
    }
  }
}
