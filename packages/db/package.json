{
  "name": "@myakiba/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "default": "./src/client.ts"
    },
    "./schema/*": {
      "default": "./src/schema/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:push": "bun src/scripts/push-schema.ts",
    "db:push:interactive": "drizzle-kit push --verbose",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:start": "docker compose up -d --wait && bun run db:push",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@myakiba/contracts": "workspace:*",
    "@myakiba/env": "workspace:*",
    "@paralleldrive/cuid2": "catalog:",
    "dotenv": "catalog:",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "postgres": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@myakiba/config": "workspace:*",
    "@types/bun": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
