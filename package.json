{
  "name": "myakiba",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^7.0.2",
      "zod": "^4.3.6",
      "@types/bun": "^1.3.9",
      "drizzle-orm": "^0.45.1",
      "drizzle-zod": "^0.8.3",
      "ioredis": "^5.9.3",
      "postgres": "^3.4.8",
      "bullmq": "^5.70.4",
      "@paralleldrive/cuid2": "^3.3.0",
      "dotenv": "^17.2.4",
      "uuid": "^13.0.0",
      "better-auth": "^1.6.23",
      "elysia": "^1.4.25",
      "date-fns": "^4.1.0",
      "evlog": "^2.4.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "stop": "turbo run db:stop redis:stop",
    "dev:native": "turbo run dev -F native",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "dev:worker": "turbo run dev -F worker",
    "db:push": "turbo run db:push -F @myakiba/db",
    "db:push:interactive": "turbo run db:push:interactive -F @myakiba/db",
    "db:studio": "turbo run db:studio -F @myakiba/db",
    "db:generate": "turbo run db:generate -F @myakiba/db",
    "db:migrate": "turbo run db:migrate -F @myakiba/db",
    "db:start": "turbo run db:start -F @myakiba/db",
    "db:watch": "turbo run db:watch -F @myakiba/db",
    "db:stop": "turbo run db:stop -F @myakiba/db",
    "db:down": "turbo run db:down -F @myakiba/db",
    "redis:start": "turbo run redis:start -F @myakiba/redis",
    "redis:stop": "turbo run redis:stop -F @myakiba/redis",
    "redis:down": "turbo run redis:down -F @myakiba/redis",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {},
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "react-doctor": "^0.2.16",
    "turbo": "2.10.4",
    "typescript": "catalog:",
    "ultracite": "7.6.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.9"
}
