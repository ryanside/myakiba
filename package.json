{
  "name": "myakiba",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^5.9.3",
      "zod": "^4.3.6",
      "@types/bun": "^1.3.9",
      "drizzle-orm": "^0.45.1",
      "drizzle-zod": "^0.8.3",
      "ioredis": "^5.9.3",
      "postgres": "^3.4.8",
      "bullmq": "^5.70.4",
      "@paralleldrive/cuid2": "^3.3.0",
      "dotenv": "^17.2.4",
      "uuid": "^13.0.0",
      "better-auth": "^1.4.18",
      "elysia": "^1.4.25",
      "date-fns": "^4.1.0",
      "evlog": "^2.4.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "stop": "turbo run db:stop redis:stop",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:worker": "turbo -F worker dev",
    "db:push": "turbo -F @myakiba/db db:push",
    "db:studio": "turbo -F @myakiba/db db:studio",
    "db:generate": "turbo -F @myakiba/db db:generate",
    "db:migrate": "turbo -F @myakiba/db db:migrate",
    "db:start": "turbo -F @myakiba/db db:start",
    "db:watch": "turbo -F @myakiba/db db:watch",
    "db:stop": "turbo -F @myakiba/db db:stop",
    "db:down": "turbo -F @myakiba/db db:down",
    "redis:start": "turbo -F @myakiba/redis redis:start",
    "redis:stop": "turbo -F @myakiba/redis redis:stop",
    "redis:down": "turbo -F @myakiba/redis redis:down",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {},
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "ultracite": "7.6.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.0"
}
